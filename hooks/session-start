#!/usr/bin/env bash
# Session-start hook for agentic-swe (Claude Code + Cursor).
# Injects Hypervisor policy context + compact implicit-routing hint.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CLAUDE_MD="$REPO_ROOT/CLAUDE.md"
HINT_FILE="$REPO_ROOT/references/session-routing-hint.md"

if [ ! -f "$CLAUDE_MD" ]; then
  echo '{"error": "CLAUDE.md not found at plugin root"}' >&2
  exit 1
fi

BASE="You are running with the agentic-swe pipeline. Follow the Hypervisor policy in CLAUDE.md. Check .worklogs/ for active work items (read state.json) before starting new work unless the user asks otherwise."

ROUTING=""
if [ -f "$HINT_FILE" ]; then
  ROUTING=$(cat "$HINT_FILE")
fi

FULL_CTX="${BASE}"$'\n\n'"${ROUTING}"

emit_json() {
  local mode="$1"
  printf '%s' "$FULL_CTX" | node -e "
    const fs = require('fs');
    const ctx = fs.readFileSync(0, 'utf8');
    const out = process.argv[1] === 'cursor'
      ? { additional_context: ctx }
      : { hookSpecificOutput: { additionalContext: ctx } };
    console.log(JSON.stringify(out));
  " "$mode"
}

if [ "${CURSOR_SESSION:-}" = "1" ] || [ "${CURSOR_PLUGIN:-}" = "1" ]; then
  emit_json cursor
else
  emit_json claude
fi
