# Runtime work state (generated per-run; Hypervisor uses .worklogs/<id>/ in target repos)
.worklogs/

# Do not commit a second copy of the pack under /.claude/ — canonical plugin paths are repo root.
# Claude Code may create this directory locally (e.g. project settings); keep it out of git.
/.claude/

# Cursor — ignore local IDE state; keep shared rules committed
.cursor/*
!.cursor/rules/
.cursor/rules/*
!.cursor/rules/git-identity-personal.mdc
!.cursor/rules/npm-registry-personal.mdc
!.cursor/rules/development-branch-workflow.mdc

# OS metadata
.DS_Store
Thumbs.db

# Editor/IDE
*.swp
*.swo
*~
.idea/
.vscode/
.sfdx/
*.sublime-*

# Local tooling (MCP / IDE; paths vary by machine)
.mcp.json

# Secrets and env (never commit real values)
.env
.env.*
!.env.example
infra/.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Marketing site build output (Vite)
site/dist/

# Node
node_modules/
*.tgz
.npm/
.pnpm-store/

# Python
__pycache__/
*.pyc
.venv/

# Test / coverage
coverage/
.nyc_output/

# Keys (if ever added by mistake)
*.pem
*.key
