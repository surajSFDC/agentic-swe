# Runtime work state (generated per-run; Hypervisor uses .worklogs/<id>/ in target repos)
.worklogs/

# Do not commit a second copy of the pack under /.claude/ — canonical plugin paths are repo root.
# Claude Code may create this directory locally (e.g. project settings); keep it out of git.
/.claude/

# Cursor — local IDE state and personal rules (never commit)
.cursor/

# OS metadata
.DS_Store
Thumbs.db

# Editor/IDE
*.swp
*.swo
*~
.idea/
.vscode/
.sfdx/
*.sublime-*

# Local tooling (MCP / IDE; paths vary by machine)
.mcp.json

# Phase 2 durable memory — local SQLite + WAL (optional JSON under .agentic-swe/ may be committed per repo)
.agentic-swe/memory.sqlite
.agentic-swe/memory.sqlite-shm
.agentic-swe/memory.sqlite-wal

# Secrets and env (never commit real values)
.env
.env.*
!.env.example

# Logs
*.log
# Pack template for per-work audit files (work-engine init copies this path)
!templates/audit.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Marketing site build output (Vite)
site/dist/

# Node
node_modules/
*.tgz
.npm/
.pnpm-store/

# Python
__pycache__/
*.pyc
.venv/

# Test / coverage
coverage/
.nyc_output/

# Keys (if ever added by mistake)
*.pem
*.key
