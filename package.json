{
  "name": "agentic-swe",
  "version": "2.0.0",
  "description": "Autonomous SWE pipeline for Claude Code — install markdown policies, phases, and agents into your repo",
  "license": "MIT",
  "author": "Suraj Gupta",
  "homepage": "https://d3pi4w4hqr9gq6.cloudfront.net",
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "swe",
    "pipeline",
    "orchestration"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "agentic-swe": "bin/agentic-swe.js"
  },
  "files": [
    "CHANGELOG.md",
    "bin",
    "scripts",
    "CLAUDE.md",
    "AGENTS.md",
    "GEMINI.md",
    ".claude/commands",
    ".claude/phases",
    ".claude/agents",
    ".claude/templates",
    ".claude/references",
    ".claude/state-machine.json",
    ".claude/tools",
    "tools/brainstorm-server/",
    ".claude-plugin/",
    ".cursor-plugin/",
    ".codex/",
    ".opencode/",
    "hooks/",
    "gemini-extension.json",
    ".version-bump.json"
  ],
  "devDependencies": {
    "ws": "^8.18.0"
  },
  "scripts": {
    "build:site": "npm run build --prefix site",
    "prepack": "node -e \"const fs=require('fs');const p=require('path');const r=p.join('.claude','phases');if(!fs.existsSync(r))process.exit(1)\"",
    "test": "node --test test/*.test.js",
    "test:smoke": "bash test/smoke/run-smoke.sh",
    "test:llm": "node test/llm/run-llm-tests.cjs",
    "verify": "node scripts/verify-sanity.js",
    "summarize-work": "node scripts/summarize-work.js",
    "version:check": "bash scripts/bump-version.sh check",
    "version:bump": "bash scripts/bump-version.sh bump"
  }
}
