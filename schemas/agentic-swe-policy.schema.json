{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentic-swe.github.io/schemas/agentic-swe-policy.schema.json",
  "title": "Agentic SWE Policy",
  "description": "Schema for organization or repository-level policy files that merge with pack defaults.",
  "type": "object",
  "properties": {
    "version": { "type": "string", "default": "1.0" },
    "track_rules": {
      "type": "array",
      "description": "Rules that force a minimum track based on file paths or patterns.",
      "items": {
        "type": "object",
        "required": ["pattern", "minimum_track"],
        "properties": {
          "pattern": { "type": "string", "description": "Glob pattern matching file paths (e.g. 'src/auth/**')" },
          "minimum_track": { "type": "string", "enum": ["lean", "standard", "rigorous"] },
          "reason": { "type": "string" }
        }
      }
    },
    "mandatory_subagents": {
      "type": "array",
      "description": "Subagents that must be spawned when certain patterns are touched.",
      "items": {
        "type": "object",
        "required": ["pattern", "subagent"],
        "properties": {
          "pattern": { "type": "string" },
          "subagent": { "type": "string", "description": "Subagent path under agents/subagents/" },
          "phase": { "type": "string", "description": "Phase where the subagent must be spawned" }
        }
      }
    },
    "banned_tools": {
      "type": "array",
      "description": "Tool combinations that are forbidden.",
      "items": {
        "type": "object",
        "required": ["tool", "reason"],
        "properties": {
          "tool": { "type": "string" },
          "context": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "required_artifacts": {
      "type": "object",
      "description": "Additional artifacts required by state (merged with pack defaults).",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "budget_overrides": {
      "type": "object",
      "description": "Override default budget thresholds.",
      "properties": {
        "max_cost_usd": { "type": "number" },
        "max_iterations": { "type": "integer" },
        "max_doubt_cycles": { "type": "integer" }
      }
    }
  },
  "additionalProperties": false
}
