{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentic-swe.github.io/schemas/typed-actions.schema.json",
  "title": "Typed Actions",
  "description": "Host-agnostic action vocabulary for agentic-swe phases. Runtime adapters translate these into host-specific commands.",
  "definitions": {
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "READ_FILE",
            "WRITE_FILE",
            "EDIT_FILE",
            "RUN",
            "SEARCH",
            "GLOB",
            "SPAWN_SUBAGENT",
            "LIST_DIR",
            "GIT",
            "WEB_FETCH"
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "READ_FILE" } } },
          "then": {
            "properties": {
              "path": { "type": "string" },
              "offset": { "type": "integer" },
              "limit": { "type": "integer" }
            },
            "required": ["path"]
          }
        },
        {
          "if": { "properties": { "type": { "const": "WRITE_FILE" } } },
          "then": {
            "properties": {
              "path": { "type": "string" },
              "contents": { "type": "string" }
            },
            "required": ["path", "contents"]
          }
        },
        {
          "if": { "properties": { "type": { "const": "RUN" } } },
          "then": {
            "properties": {
              "command": { "type": "string" },
              "cwd": { "type": "string" },
              "timeout_ms": { "type": "integer" }
            },
            "required": ["command"]
          }
        },
        {
          "if": { "properties": { "type": { "const": "SPAWN_SUBAGENT" } } },
          "then": {
            "properties": {
              "prompt": { "type": "string" },
              "description": { "type": "string" },
              "background": { "type": "boolean" }
            },
            "required": ["prompt"]
          }
        }
      ]
    }
  },
  "type": "object",
  "properties": {
    "actions": {
      "type": "array",
      "items": { "$ref": "#/definitions/action" }
    }
  }
}
