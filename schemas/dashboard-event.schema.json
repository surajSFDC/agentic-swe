{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentic-swe.github.io/schemas/dashboard-event.schema.json",
  "title": "Dashboard Event",
  "description": "Typed events emitted by the agentic-swe pipeline for real-time dashboard consumption.",
  "type": "object",
  "required": ["type", "timestamp", "work_id"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "state_changed",
        "gate_open",
        "gate_resolved",
        "cost_tick",
        "doubt_finding",
        "subagent_spawned",
        "subagent_returned",
        "artifact_written",
        "budget_warning",
        "error"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "work_id": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "description": "Event-specific payload.",
      "properties": {
        "from_state": { "type": "string" },
        "to_state": { "type": "string" },
        "track": { "type": "string" },
        "gate_type": { "type": "string", "enum": ["ambiguity-wait", "approval-wait", "escalation"] },
        "gate_action": { "type": "string", "enum": ["opened", "resolved", "timeout"] },
        "cost_used": { "type": "number" },
        "cost_budget": { "type": "number" },
        "budget_remaining": { "type": "number" },
        "phase": { "type": "string" },
        "subagent_type": { "type": "string" },
        "artifact_name": { "type": "string" },
        "finding_severity": { "type": "string", "enum": ["high", "medium", "low"] },
        "finding_text": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
