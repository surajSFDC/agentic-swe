{
  "schema_version": 1,
  "description": "Default durable memory / graph settings. Override in target repo with .agentic-swe/memory.json (merge) or AGENTIC_SWE_MEMORY_CONFIG=/abs/path.json.",
  "store": {
    "sqlite_relative_path": "memory.sqlite",
    "directory_relative": ".agentic-swe"
  },
  "ingest": {
    "include_globs": [
      "AGENTS.md",
      "CLAUDE.md",
      "docs/**/*.md",
      ".worklogs/**/*.md"
    ],
    "exclude_globs": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.git/**",
      "**/coverage/**"
    ],
    "max_file_bytes": 1048576,
    "max_chunk_chars": 8000,
    "chunk_extensions": [".md"]
  },
  "prime": {
    "max_chars_out": 12000,
    "max_fts_hits": 12
  },
  "graph": {
    "enabled": true,
    "package_manifests": ["package.json", "package-lock.json"]
  },
  "import_adapter": {
    "enabled": false,
    "max_nodes_per_merge": 5000,
    "max_edges_per_merge": 20000
  }
}
